{
  "plugins": [
    "prettier-plugin-organize-imports",
    "prettier-plugin-packagejson"
  ],
  "semi": true,
  "endOfLine": "lf",
  "singleQuote": true,
  "overrides": [
    {
      "files": ["**/*.md", "**/*.mdx"],
      "options": {
        "tabWidth": 4
      }
    },
    {
      "files": [
        "packages/v*/source/temp/copied/**/*.d.ts",
        "packages/v*/source/temp/copied-for-diff/**/*.d.ts",
        "packages/v*/source/temp/eslint-fixed/**/*.d.ts"
      ],
      "options": {
        "printWidth": 320
      }
    }
  ]
}
