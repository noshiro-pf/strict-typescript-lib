{
  "name": "strict-typescript-lib",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "typescript"
  ],
  "license": "Apache-2.0",
  "author": "noshiro-pf <noshiro.pf@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noshiro-pf/strict-typescript-lib.git"
  },
  "workspaces": [
    "packages/**"
  ],
  "type": "module",
  "scripts": {
    "agents:gen": "tsx ./scripts/cmd/gen-agents-md.mts",
    "agents:sync": "tsx ./scripts/cmd/sync-agent-config.mts",
    "check:root": "pnpm run '/check:root:.*/'",
    "check:root:type": "tsc -p ./tsconfig.json --noEmit",
    "check:root:tooling": "tsc -p ./tsconfig.tooling.json --noEmit",
    "changeset:all": "tsx ./scripts/cmd/create-changeset.mts",
    "changeset:version-packages": "pnpm changeset version && pnpm run ws:gen:packages && pnpm install --no-frozen-lockfile",
    "changeset:publish": "pnpm run ws:gen:packages && tsx ./scripts/cmd/publish-packages.mts",
    "check-all": "tsx ./scripts/cmd/check-all.mts",
    "codemod": "run-s codemod:uncommitted:as-const fmt codemod:uncommitted:readonly fmt",
    "codemod:diff": "run-s codemod:diff:as-const fmt codemod:diff:readonly fmt",
    "codemod:diff:as-const": "append-as-const --diff-from origin/main '**/*.mts'",
    "codemod:diff:readonly": "convert-to-readonly --diff-from origin/main '**/*.mts'",
    "codemod:full": "run-s codemod:full:as-const fmt codemod:full:readonly fmt",
    "codemod:full:as-const": "append-as-const '**/*.mts'",
    "codemod:full:readonly": "convert-to-readonly '**/*.mts'",
    "codemod:uncommitted:as-const": "append-as-const --uncommitted '**/*.mts'",
    "codemod:uncommitted:readonly": "convert-to-readonly --uncommitted '**/*.mts'",
    "clean:node_modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "cspell": "cspell \"**\" --gitignore --gitignore-root ./ --no-progress",
    "fmt": "oxfmt --ignore-path=.gitignore --ignore-path=.oxfmtignore .",
    "gen:version-diff": "tsx ./scripts/cmd/gen-version-diff.mts",
    "gh:apply-all": "gh-apply-all",
    "gh:apply-repository-settings": "gh-apply-repository-settings",
    "gh:apply-rulesets": "gh-apply-rulesets",
    "gh:apply-variables": "gh-apply-variables",
    "gh:backup-all": "gh-backup-all",
    "gh:backup-repository-settings": "gh-backup-repository-settings",
    "gh:backup-rulesets": "gh-backup-rulesets",
    "lint": "pnpm run z:eslint .",
    "lint:fix": "pnpm run z:eslint . --fix",
    "md": "markdownlint-cli2",
    "update-dependencies": "pnpm update --latest -r '!typescript' '!eslint'",
    "ws:gen": "tsx ./scripts/cmd/ws-gen-stages.mts",
    "ws:gen:full": "tsx ./scripts/cmd/ws-gen-full-stages.mts",
    "ws:gen:with-codemod-fixed": "tsx ./scripts/cmd/ws-gen-with-codemod-fixed-stages.mts",
    "ws:gen:packages": "tsx ./scripts/cmd/ws-gen-packages-stages.mts",
    "ws:type-check": "pnpm run --recursive --if-present type-check",
    "z:eslint": "NODE_OPTIONS='--max-old-space-size=6144' TIMING=1 eslint",
    "publish:packages": "tsx ./scripts/cmd/publish-packages.mts"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "26.1.1",
    "@typescript/lib-decorators": "file:packages/v5.9/output/packages/decorators",
    "@typescript/lib-dom": "file:packages/v5.9/output/packages/dom",
    "@typescript/lib-es2015": "file:packages/v5.9/output/packages/es2015",
    "@typescript/lib-es2016": "file:packages/v5.9/output/packages/es2016",
    "@typescript/lib-es2017": "file:packages/v5.9/output/packages/es2017",
    "@typescript/lib-es2018": "file:packages/v5.9/output/packages/es2018",
    "@typescript/lib-es2019": "file:packages/v5.9/output/packages/es2019",
    "@typescript/lib-es2020": "file:packages/v5.9/output/packages/es2020",
    "@typescript/lib-es2021": "file:packages/v5.9/output/packages/es2021",
    "@typescript/lib-es2022": "file:packages/v5.9/output/packages/es2022",
    "@typescript/lib-es2023": "file:packages/v5.9/output/packages/es2023",
    "@typescript/lib-es2024": "file:packages/v5.9/output/packages/es2024",
    "@typescript/lib-es5": "file:packages/v5.9/output/packages/es5",
    "@typescript/lib-es6": "file:packages/v5.9/output/packages/es6",
    "@typescript/lib-esnext": "file:packages/v5.9/output/packages/esnext",
    "@typescript/lib-scripthost": "file:packages/v5.9/output/packages/scripthost",
    "@typescript/lib-webworker": "file:packages/v5.9/output/packages/webworker",
    "cspell": "10.0.1",
    "dedent": "^1.7.2",
    "eslint": "9.39.4",
    "eslint-config-typed": "5.6.2",
    "eslint-plugin-ts-data-forge": "^0.1.3",
    "github-settings-as-code": "1.2.9",
    "jiti": "2.7.0",
    "markdownlint": "0.41.1",
    "markdownlint-cli2": "0.23.0",
    "npm-run-all2": "^9.0.2",
    "oxfmt": "0.59.0",
    "ts-codemod-lib": "^2.2.2",
    "ts-data-forge": "12.0.0",
    "ts-fortress": "7.3.0",
    "ts-repo-utils": "10.1.3",
    "ts-type-forge": "7.2.1",
    "tslib": "2.8.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.22.2",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "26.3.1"
  },
  "packageManager": "pnpm@11.15.1"
}
