{
  "name": "strict-typescript-lib",
  "version": "0.0.0",
  "private": true,
  "keywords": [
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noshiro-pf/strict-typescript-lib.git"
  },
  "license": "Apache-2.0",
  "author": "noshiro-pf <noshiro.pf@gmail.com>",
  "type": "module",
  "workspaces": [
    "packages/**"
  ],
  "scripts": {
    "check:root": "pnpm run '/check:root:.*/'",
    "check:root:lint": "pnpm run z:eslint ./{scripts,configs}/**/*.mts --fix",
    "check:root:type": "tsc -p ./tsconfig.json --noEmit",
    "check-all": "tsx ./scripts/cmd/check-all.mts",
    "ci:publish": "pnpm run ws:build && pnpm changeset publish",
    "ci:version-packages": "pnpm changeset version && pnpm install --no-frozen-lockfile",
    "clean:node_modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
    "cspell": "cspell \"**\" --gitignore --gitignore-root ./ --no-progress",
    "fmt": "format-uncommitted",
    "fmt:diff": "format-diff-from origin/main",
    "fmt:full": "prettier --ignore-unknown --no-error-on-unmatched-pattern --write .",
    "gh:apply-all": "gh-apply-all",
    "gh:apply-repository-settings": "gh-apply-repository-settings",
    "gh:apply-rulesets": "gh-apply-rulesets",
    "gh:apply-variables": "gh-apply-variables",
    "gh:backup-all": "gh-backup-all",
    "gh:backup-repository-settings": "gh-backup-repository-settings",
    "gh:backup-rulesets": "gh-backup-rulesets",
    "md": "markdownlint-cli2",
    "update-dependencies": "pnpm update --latest -r",
    "ws:build": "tsx ./scripts/cmd/ws-build-stages.mts",
    "ws:gen": "pnpm -r --filter './packages/v*/source' run gen:full",
    "ws:lint": "pnpm run --recursive --if-present lint",
    "ws:lint:fix": "pnpm run --recursive --if-present lint:fix",
    "ws:test": "pnpm run --recursive --if-present test",
    "ws:tsc": "pnpm run --recursive --if-present tsc",
    "ws:type-check": "pnpm run --recursive --if-present type-check",
    "z:eslint": "NODE_OPTIONS='--max-old-space-size=6144' TIMING=1 eslint"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "25.9.1",
    "cspell": "10.0.0",
    "eslint": "9.39.4",
    "eslint-config-typed": "4.9.11",
    "github-settings-as-code": "1.2.9",
    "jiti": "2.7.0",
    "markdownlint": "0.40.0",
    "markdownlint-cli2": "0.22.1",
    "prettier": "3.8.3",
    "prettier-plugin-organize-imports": "4.3.0",
    "prettier-plugin-packagejson": "3.0.2",
    "ts-codemod-lib": "2.2.0",
    "ts-data-forge": "6.9.6",
    "ts-repo-utils": "10.1.2",
    "ts-type-forge": "3.1.0",
    "tslib": "2.8.1",
    "tsx": "4.22.3",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=9.0.0"
  },
  "volta": {
    "node": "25.9.0"
  }
}
